generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum Role {
  ADMIN
  USER
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String
  role      Role      @default(USER)
  articles  Article[]
  media     Media[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Article {
  id           String        @id @default(cuid())
  title        String
  slug         String        @unique
  excerpt      String?
  content      String
  magazineJson Json?
  coverImage   String?
  category     Category?     @relation(fields: [categoryId], references: [id])
  categoryId   String?
  tags         String[]
  status       ArticleStatus @default(DRAFT)
  author       User          @relation(fields: [authorId], references: [id])
  authorId     String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([slug])
  @@index([status])
  @@index([categoryId])
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  articles Article[]
}

model Media {
  id         String   @id @default(cuid())
  url        String
  filename   String
  mimeType   String
  size       Int
  uploadedBy User     @relation(fields: [userId], references: [id])
  userId     String
  createdAt  DateTime @default(now())
}

model PageContent {
  id        String   @id @default(cuid())
  pageSlug  String   @unique
  title     String
  sections  Json
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
